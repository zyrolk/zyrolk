rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    function isValidImageUpload() {
      return request.resource != null &&
             request.resource.size < 10 * 1024 * 1024 &&
             request.resource.contentType.matches('image/.*');
    }

    // Publicly readable media; only authenticated admins may upload validated images.
    match /banners/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImageUpload();
      allow delete: if isAdmin();
    }
    match /logos/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImageUpload();
      allow delete: if isAdmin();
    }

    // Supplier originals and optimized variants are written only through the
    // Admin SDK. Review assets are visible to admins; customer reads start only
    // after the immutable asset record has been marked published by approval.
    match /supplier-media/{supplierId}/{productId}/{assetId}/{variant}/{fileName} {
      allow read: if isAdmin() ||
        (variant != 'original' &&
         firestore.get(/databases/(default)/documents/supplier_media_assets/$(assetId)).data.imageStatus == 'published');
      allow create, update, delete: if false;
    }
  }
}
