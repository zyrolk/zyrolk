# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# API_ALLOWED_ORIGINS: Comma-separated production storefront origins.
# Defaults to these exact production and Firebase Hosting origins when omitted.
API_ALLOWED_ORIGINS="https://zyro.lk,https://www.zyro.lk,https://zyrolk-e0164.web.app"

# ALLOWED_SUPPLIER_DOMAINS: Optional comma-separated supplier host allowlist.
# Supplier hosts stored in Firestore remain subject to the server-side SSRF checks.
ALLOWED_SUPPLIER_DOMAINS="supplier.example.com"

# A2Z supplier credentials: only needed when using the A2Z supplier sync.
# Keep real values in .env.local or production secrets, never in source code.
A2Z_USERNAME="MY_A2Z_USERNAME"
A2Z_PASSWORD="MY_A2Z_PASSWORD"

# Cloudinary browser-upload configuration. Use an unsigned preset restricted in Cloudinary.
VITE_CLOUDINARY_CLOUD_NAME="MY_CLOUDINARY_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="MY_CLOUDINARY_UNSIGNED_UPLOAD_PRESET"

# PayHere checkout is signed and verified by the server. Keep the merchant secret
# in Firebase Secret Manager; never add it to this file or a Vite variable.
PAYHERE_MODE="sandbox"
PAYHERE_MERCHANT_ID="MY_PAYHERE_MERCHANT_ID"
PUBLIC_SITE_URL="https://zyro.lk"

# Secure default is enabled. Set false only for a controlled emulator session.
REQUIRE_APP_CHECK="true"
VITE_FIREBASE_APP_CHECK_SITE_KEY="MY_RECAPTCHA_ENTERPRISE_SITE_KEY"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"
