rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global administrators are granted by trusted Firebase custom claims.
    // Browser profile documents are never an authorization source.
    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    // Supplier Hub administration is an Auth custom-claim capability. The
    // browser cannot mint it by changing a Firestore user profile.
    function isSupplierHubAdmin() {
      return isAdmin() ||
             (request.auth != null && request.auth.token.supplierHubAdmin == true);
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSupplier() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier';
    }

    function isValidCustomerAddress(data) {
      return data.keys().hasOnly([
               'label', 'fullName', 'phone', 'addressLine1', 'addressLine2',
               'city', 'district', 'postalCode', 'isDefault', 'createdAt', 'updatedAt'
             ]) &&
             data.label is string && data.label.size() >= 1 && data.label.size() <= 40 &&
             data.fullName is string && data.fullName.size() >= 1 && data.fullName.size() <= 120 &&
             data.phone is string && data.phone.size() >= 9 && data.phone.size() <= 30 &&
             data.addressLine1 is string && data.addressLine1.size() >= 1 && data.addressLine1.size() <= 240 &&
             data.addressLine2 is string && data.addressLine2.size() <= 240 &&
             data.city is string && data.city.size() >= 1 && data.city.size() <= 80 &&
             data.district is string && data.district.size() >= 1 && data.district.size() <= 80 &&
             data.postalCode is string && data.postalCode.size() <= 20 &&
             data.isDefault is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isPublicProductData(data) {
      return !data.keys().hasAny([
        'supplierItemCode', 'supplierItemCodeNormalized', 'supplierId',
        'costPrice', 'marketPrice', 'supplierPurchasePrice',
        'supplierInternalNotes', 'supplierProfit', 'supplierPrice',
        'purchasePrice', 'profitMargin', 'commission',
        'supplierMetadata', 'supplierCommercialMetadata', 'wholesalePrice',
        'supplierMedia',
        'recommendedRetailPrice', 'supplierCode', 'supplierSku', 'supplierSKU',
        'supplierCost', 'internalCost', 'margin', 'profit',
        'supplierSourceId', 'supplierSource', 'supplierLeadTime',
        'supplierMoq', 'supplierMOQ'
      ]);
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isPublicProductData(request.resource.data);
      allow delete: if isAdmin();
    }

    // Commercial product data is never stored in the public catalogue document.
    // Suppliers receive an explicit allowlisted projection through the trusted API.
    match /product_private/{productId} {
      allow read, write: if isAdmin();
    }

    // Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Brand registry: public catalogue metadata, managed only by admins.
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow creation only if the user is authenticated, writing their own document, and initializing role as 'customer'
      allow create: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.data.role == 'customer';
      // Prevent privilege escalation: only admins can change roles, users can update other details but cannot escalate themselves to admin
      allow update: if isAdmin() || (
                      isOwner(userId) && 
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
                    );
      allow delete: if isAdmin();
    }

    // Customer Account Center address book. Addresses remain private to their owner.
    match /users/{userId}/addresses/{addressId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin() || (
                              isOwner(userId) &&
                              isValidCustomerAddress(request.resource.data)
                            );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true;
      // Review mutations require trusted verification of purchase, ownership and duplicate prevention.
      allow create, update, delete: if false;

      match /votes/{userId} {
        allow read, write: if false;
      }

      match /reports/{userId} {
        allow read, write: if false;
      }
    }

    // Product Q&A is public to read and is mutated only through the authenticated review API.
    match /productQuestions/{questionId} {
      allow read: if true;
      allow create, update, delete: if false;

      match /votes/{userId} {
        allow read, write: if false;
      }
    }

    // Settings Rules - Only authenticated admins can edit website settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pages Rules
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy Supplier Hub records are read-only to authenticated Supplier Hub
    // administrators. Operational writes are Functions/Admin-SDK only.
    match /supplierHub/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Source definitions are projected through the API. This prevents old
    // credential-bearing source records from being exposed to a browser.
    match /supplierSources/{docId} {
      allow read, create, update, delete: if false;
    }

    // Legacy sync log collection is server-written only.
    match /supplierSyncLogs/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Queue state is a server-authoritative state machine.
    match /supplier_review_queue/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Import staging is written only by trusted workers.
    match /supplier_import_queue/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Pending changes are materialized from the durable queue by Functions.
    match /supplier_pending_changes/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Sync history is an operational record, never a browser write target.
    match /supplier_sync_history/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Supplier Approval Audit Rules
    match /supplier_approval_audit/{docId} {
      // The append-only ledger is written exclusively by trusted Functions using
      // the Admin SDK. Even an administrator's browser cannot alter history.
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Conflict records are generated by trusted supplier workers. Administrators
    // may inspect them, but neither suppliers nor browser clients can alter them.
    match /supplier_product_conflicts/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Supplier catalog mappings are learned and versioned only by trusted
    // approval Functions. Browsers may inspect suggestions through queue data,
    // but cannot train or override the mapping engine directly.
    match /supplier_category_mappings/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    match /supplier_brand_mappings/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    match /supplier_mapping_audit/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Full supplier media metadata contains original upstream URLs and remains
    // server-authoritative. Public products receive only the published projection.
    match /supplier_media_assets/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    match /supplier_media_audit/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Error-center dispositions are operational metadata written only through
    // authenticated Functions. They never mutate the underlying audit event.
    match /supplier_operation_error_states/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    match /supplier_operations_audit/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Supplier Sync Lock Rules
    match /supplier_sync_locks/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Settings are edited through the validated Supplier Hub configuration API.
    match /supplier_settings/{docId} {
      allow read: if isSupplierHubAdmin();
      allow create, update, delete: if false;
    }

    // Supplier Portal request payloads are projected by the trusted API so nested
    // workflow data cannot bypass the supplier response allowlist.
    match /supplier_profiles/{supplierId} {
      allow read: if isSupplierHubAdmin() || (isSupplier() && isOwner(supplierId));
      allow write: if false;
    }

    match /supplier_product_requests/{requestId} {
      allow read: if isSupplierHubAdmin();
      allow write: if false;
    }

    match /supplier_notifications/{notificationId} {
      allow read: if isSupplierHubAdmin() || (isSupplier() && resource.data.supplierId == request.auth.uid);
      allow write: if false;
    }

    match /supplier_sku_claims/{claimId} {
      allow read: if false;
      allow write: if false;
    }

    match /supplier_product_claims/{claimId} {
      allow read: if false;
      allow write: if false;
    }

    // Orders Rules
    match /orders/{orderId} {
      // Customers can read their own orders. Admins can read all.
      allow read: if isAdmin() || (request.auth != null && resource.data.customerUid == request.auth.uid);
      // Orders are created and mutated only by trusted backend transactions.
      allow create, update, delete: if false;
    }

    match /contact_inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'phone', 'email', 'message', 'status', 'createdAt'
      ]) &&
      request.resource.data.name is string && request.resource.data.name.size() >= 1 && request.resource.data.name.size() <= 120 &&
      request.resource.data.phone is string && request.resource.data.phone.size() >= 9 && request.resource.data.phone.size() <= 30 &&
      request.resource.data.email is string && request.resource.data.email.size() <= 160 &&
      request.resource.data.message is string && request.resource.data.message.size() >= 1 && request.resource.data.message.size() <= 2000 &&
      request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // Checkout idempotency records are written only by trusted backend code.
    match /checkout_idempotency/{docId} {
      allow read, write: if false;
    }

    // Distributed checkout abuse counters contain hashed network/customer signals only.
    match /checkout_abuse_limits/{docId} {
      allow read, write: if false;
    }

    // Coupon definitions are private operational data. Customers validate codes through the trusted checkout API.
    match /checkout_coupons/{couponId} {
      allow read, write: if isAdmin();
    }

    // Payment verification, provider receipts and notification delivery are trusted-server only.
    match /payment_transactions/{transactionId} {
      allow read, write: if false;
    }

    match /payment_receipts/{receiptId} {
      allow read, write: if false;
    }

    match /notification_outbox/{notificationId} {
      allow read, write: if false;
    }

    match /mail/{mailId} {
      allow read, write: if false;
    }

    // Production clients do not use a public connection-test collection.
    match /test/{docId} {
      allow read, write: if false;
    }
  }
}
