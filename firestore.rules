rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'zyrolkofficial@gmail.com';
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidReviewData(data) {
      return data.keys().hasOnly([
               'userId', 'userName', 'customerName', 'productId', 'comment', 'rating', 'createdAt'
             ]) &&
             data.userId is string &&
             data.userId.size() >= 1 && data.userId.size() <= 128 &&
             data.userName is string &&
             data.userName.size() >= 1 && data.userName.size() <= 120 &&
             data.customerName is string &&
             data.customerName.size() >= 1 && data.customerName.size() <= 120 &&
             data.productId is string &&
             data.productId.size() >= 1 && data.productId.size() <= 128 &&
             data.comment is string &&
             data.comment.size() >= 1 && data.comment.size() <= 2000 &&
             data.rating is number &&
             data.rating >= 1 &&
             data.rating <= 5 &&
             data.createdAt is string &&
             data.createdAt.size() <= 64;
    }

    function isValidCustomerAddress(data) {
      return data.keys().hasOnly([
               'label', 'fullName', 'phone', 'addressLine1', 'addressLine2',
               'city', 'district', 'postalCode', 'isDefault', 'createdAt', 'updatedAt'
             ]) &&
             data.label is string && data.label.size() >= 1 && data.label.size() <= 40 &&
             data.fullName is string && data.fullName.size() >= 1 && data.fullName.size() <= 120 &&
             data.phone is string && data.phone.size() >= 9 && data.phone.size() <= 30 &&
             data.addressLine1 is string && data.addressLine1.size() >= 1 && data.addressLine1.size() <= 240 &&
             data.addressLine2 is string && data.addressLine2.size() <= 240 &&
             data.city is string && data.city.size() >= 1 && data.city.size() <= 80 &&
             data.district is string && data.district.size() >= 1 && data.district.size() <= 80 &&
             data.postalCode is string && data.postalCode.size() <= 20 &&
             data.isDefault is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow creation only if the user is authenticated, writing their own document, and initializing role as 'customer'
      allow create: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.data.role == 'customer';
      // Prevent privilege escalation: only admins can change roles, users can update other details but cannot escalate themselves to admin
      allow update: if isAdmin() || (
                      isOwner(userId) && 
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
                    );
      allow delete: if isAdmin();
    }

    // Customer Account Center address book. Addresses remain private to their owner.
    match /users/{userId}/addresses/{addressId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin() || (
                              isOwner(userId) &&
                              isValidCustomerAddress(request.resource.data)
                            );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true;
      // Authenticated customers can create and manage only their own review documents.
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidReviewData(request.resource.data);
      allow update: if isAdmin() || (
                    request.auth != null &&
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.productId == resource.data.productId &&
                    isValidReviewData(request.resource.data)
                  );
      allow delete: if isAdmin() || (
                    request.auth != null &&
                    resource.data.userId == request.auth.uid
                  );
    }

    // Settings Rules - Only authenticated admins can edit website settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pages Rules
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Supplier Hub Rules - Only authenticated admins can read/write
    match /supplierHub/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Sources Rules - Only authenticated admins can read/write
    match /supplierSources/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Sync Logs Rules - Only authenticated admins can read/write
    match /supplierSyncLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Review Queue Rules - Only authenticated admins can read/write
    match /supplier_review_queue/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Import Queue Rules - Only authenticated admins can read/write
    match /supplier_import_queue/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Pending Changes Rules
    match /supplier_pending_changes/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Sync History Rules
    match /supplier_sync_history/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Approval Audit Rules
    match /supplier_approval_audit/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Sync Lock Rules
    match /supplier_sync_locks/{docId} {
      allow read, write: if isAdmin();
    }

    // Supplier Settings Rules
    match /supplier_settings/{docId} {
      allow read, write: if isAdmin();
    }

    // Orders Rules
    match /orders/{orderId} {
      // Customers can read their own orders. Admins can read all.
      allow read: if isAdmin() || (request.auth != null && resource.data.customerUid == request.auth.uid);
      // Orders are created and mutated only by trusted backend transactions.
      allow create, update, delete: if false;
    }

    match /contact_inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'phone', 'email', 'message', 'status', 'createdAt'
      ]) &&
      request.resource.data.name is string && request.resource.data.name.size() >= 1 && request.resource.data.name.size() <= 120 &&
      request.resource.data.phone is string && request.resource.data.phone.size() >= 9 && request.resource.data.phone.size() <= 30 &&
      request.resource.data.email is string && request.resource.data.email.size() <= 160 &&
      request.resource.data.message is string && request.resource.data.message.size() >= 1 && request.resource.data.message.size() <= 2000 &&
      request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // Checkout idempotency records are written only by trusted backend code.
    match /checkout_idempotency/{docId} {
      allow read, write: if false;
    }

    // Production clients do not use a public connection-test collection.
    match /test/{docId} {
      allow read, write: if false;
    }
  }
}
